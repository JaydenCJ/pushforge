{
  "name": "pushforge",
  "version": "0.1.0",
  "description": "Self-hosted Web Push sender: VAPID keys, RFC 8291 encryption, a subscription store and a retrying delivery queue — standard browser push with zero runtime dependencies, built on Node's webcrypto.",
  "author": "JaydenCJ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pushforge": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "web-push",
    "vapid",
    "rfc8291",
    "push-notifications",
    "self-hosted",
    "service-worker",
    "webcrypto"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/pushforge.git"
  },
  "homepage": "https://github.com/JaydenCJ/pushforge#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/pushforge/issues"
  }
}
